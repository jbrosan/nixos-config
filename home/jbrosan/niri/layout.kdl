// Shared Niri layout configuration.

// Global blur quality for semitransparent windows and Noctalia surfaces.
blur {
    passes 3
    offset 3
    noise 0.02
    saturation 1.15
}

layout {
    gaps 12
    center-focused-column "on-overflow"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.8; }

    focus-ring {
        off
    }

    border {
        on
        width 3
        active-color "#b30000"
        inactive-color "#202020"
        urgent-color "#ff2020"
    }

    shadow {
        on
        softness 24
        spread 2
        offset x=0 y=4
        color "#00000099"
    }
}

// Slightly slower shared Niri animations.
animations {
    slowdown 1.25
}
